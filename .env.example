# ---------------------------------------------------------------------------
# DevOps Agent configuration. Copy to `.env` and fill in what you use.
# Every variable is optional except the LLM credential. Tools that need a
# backend they can't reach simply report that it's not configured.
# ---------------------------------------------------------------------------

# --- LLM credential (pick one path) ---------------------------------------
# Anthropic API (default provider). The Anthropic SDK reads this directly.
ANTHROPIC_API_KEY=

# To run on Claude via Amazon Bedrock instead, set provider=bedrock and use
# your normal AWS credentials/role. Install with: uv sync --extra bedrock
#
# No Anthropic key and no AWS? Use GitHub Models (OpenAI-compatible) — set
# provider=github and a GitHub token with the "models: read" permission below.
# Install with: uv sync --extra github
DEVOPS_AGENT_LLM_PROVIDER=anthropic        # anthropic | bedrock | github
DEVOPS_AGENT_MODEL=claude-opus-4-8         # for github, e.g. openai/gpt-4o
DEVOPS_AGENT_MAX_TOKENS=8000
DEVOPS_AGENT_THINKING=true                 # adaptive extended thinking (anthropic)

# GitHub Models (only when provider=github). Generate a fine-grained PAT with
# the "models: read" permission at github.com/settings/personal-access-tokens
GITHUB_MODELS_TOKEN=
DEVOPS_AGENT_GITHUB_MODEL=openai/gpt-4o

# --- Safety ---------------------------------------------------------------
# Mutating actions (apply/delete/scale/rollout/restart/upgrade) are blocked
# unless this is true. Leave false for triage-only operation.
DEVOPS_AGENT_ALLOW_MUTATIONS=false
DEVOPS_AGENT_COMMAND_TIMEOUT=60            # seconds per shell command
DEVOPS_AGENT_MAX_OUTPUT_CHARS=20000        # truncate tool output to this size

# --- Kubernetes / Helm ----------------------------------------------------
DEVOPS_AGENT_KUBE_CONTEXT=                 # kube context; empty = current
DEVOPS_AGENT_KUBE_NAMESPACE=               # default namespace; empty = default

# --- AWS (EKS / EC2) ------------------------------------------------------
AWS_REGION=us-east-1
DEVOPS_AGENT_AWS_PROFILE=                  # named profile; empty = default chain

# --- Prometheus -----------------------------------------------------------
DEVOPS_AGENT_PROMETHEUS_URL=               # e.g. https://prometheus.example.com
DEVOPS_AGENT_PROMETHEUS_TOKEN=             # optional bearer token

# --- Grafana --------------------------------------------------------------
DEVOPS_AGENT_GRAFANA_URL=                  # e.g. https://grafana.example.com
DEVOPS_AGENT_GRAFANA_TOKEN=                # service-account / API token

# --- Datadog --------------------------------------------------------------
DD_API_KEY=
DD_APP_KEY=
DEVOPS_AGENT_DATADOG_SITE=datadoghq.com    # e.g. datadoghq.eu, us5.datadoghq.com

# --- CI/CD (Jenkins) ------------------------------------------------------
DEVOPS_AGENT_JENKINS_URL=                  # e.g. https://jenkins.example.com
DEVOPS_AGENT_JENKINS_USER=
DEVOPS_AGENT_JENKINS_TOKEN=                # Jenkins API token
